PORT=8000
NODE_ENV=development
# Atlas: paste your connection string from MongoDB Atlas (Network Access must allow your IP)
MONGO_URI=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/?ssl=true&replicaSet=...&authSource=admin
MONGO_DB_NAME=kd_sarees
JWT_SECRET=your_long_random_secret
JWT_REFRESH_SECRET=your_long_random_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
ADMIN_EMAIL=admin@kdsarees.com
ADMIN_PASSWORD=change_this_strong_password
ADMIN_NAME=KD Sarees Admin
